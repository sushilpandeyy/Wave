# Copy to .env and adjust as needed.
POSTGRES_DSN=postgresql+asyncpg://wave:wave@localhost:5432/wave
REDIS_URL=redis://localhost:6379/0

# Budget: the one cost dial — max total concurrent workers across all pools.
W_MAX=32
# Workers reserved for enterprise only (the floor that keeps premium++ stable).
ENTERPRISE_FLOOR=4
STANDARD_FLOOR=4
# Worker coroutines a single worker container may run.
WORKERS_PER_CONTAINER=16

# Pool-health routing inputs.
LATENCY_TARGET_S=2.0   # latency EWMA "line"; above it, pressure rises
ERROR_CIRCUIT=0.5      # error rate that trips the circuit breaker

# Graceful rate limiting + notices.
APPROACHING_FRAC=0.2   # gentle heads-up when remaining tokens drop to this share of burst
NOTICE_COOLDOWN_S=60   # min seconds before repeating the same kind of notice to a user
IP_RPM=120             # coarse per-IP connection guard (sustained)
IP_BURST=40            # coarse per-IP connection guard (burst)
