# Copy to .env and adjust as needed.
POSTGRES_DSN=postgresql+asyncpg://wave:wave@localhost:5432/wave
REDIS_URL=redis://localhost:6379/0

# Budget: the one cost dial — max total concurrent workers across all pools.
W_MAX=32
# Workers reserved for enterprise only (the floor that keeps premium++ stable).
ENTERPRISE_FLOOR=4
STANDARD_FLOOR=4
# Worker coroutines a single worker container may run.
WORKERS_PER_CONTAINER=16

# Pool-health routing inputs.
LATENCY_TARGET_S=2.0   # latency EWMA "line"; above it, pressure rises
ERROR_CIRCUIT=0.5      # error rate that trips the circuit breaker

# Observability.
LOG_LEVEL=INFO
SLOW_OP_MS=250          # operations slower than this auto-log a WARNING
ANALYTICS_QUEUE_MAX=10000
ANALYTICS_WATERMARK=0.8 # past this fraction, verbose events are dropped (critical kept)
ANALYTICS_BATCH=200
ANALYTICS_FLUSH_MS=250
EVENTS_STREAM_MAX=10000 # capped raw-event stream (wave:events)
SHUTDOWN_DRAIN_S=5      # bounded analytics drain on shutdown

# Session-end personality reflection (the `reflector` service).
SESSION_IDLE_TIMEOUT_S=1800  # close a session after this much inactivity
REAPER_INTERVAL_S=30
REFLECT_MIN_MESSAGES=4       # skip reflecting trivial sessions
REFLECT_CONCURRENCY=4        # bound concurrent reflection LLM calls
REFLECT_MSG_LIMIT=100        # transcript size fed to the model
TRAIT_ALPHA=0.3             # learning rate: how fast traits move (gradual)
SUMMARY_MAX_CHARS=800

# LLM (OpenAI GPT). No key -> the mock client is used (dev / offline).
OPENAI_API_KEY=
MODEL_PREMIUM=gpt-4o
MODEL_STANDARD=gpt-4o-mini
MODEL_FAST=gpt-4o-mini

# Graceful rate limiting + notices.
APPROACHING_FRAC=0.2   # gentle heads-up when remaining tokens drop to this share of burst
NOTICE_COOLDOWN_S=60   # min seconds before repeating the same kind of notice to a user
IP_RPM=120             # coarse per-IP connection guard (sustained)
IP_BURST=40            # coarse per-IP connection guard (burst)
